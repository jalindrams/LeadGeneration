# ======================
# Micraft Growth Engine
# ======================

# Database
DATABASE_URL=postgresql://micraft:micraft_pass@localhost:5432/micraft_leads

# Google Maps Places API — FREE TIER ONLY, never paid.
# App-wide hard cap on Places calls per month (guard: app/utils/places_budget.py).
# 4000 sits under Google's smallest per-SKU free tier (5000/month).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
PLACES_MONTHLY_CALL_CAP=4000

# Scraper Settings
SCRAPE_DELAY_MIN=3
SCRAPE_DELAY_MAX=8
SCRAPE_MAX_PAGES=5

# Target Cities (comma-separated)
TARGET_CITIES=Pune,Mumbai,Chennai,Ahmedabad

# Target Industries (comma-separated search terms for IndiaMART)
TARGET_SEARCHES=Automotive Manufacturer, Pharmaceutical Manufacturer, Electronics Manufacturer, Food Beverage Manufacturer, Aerospace Manufacturer

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# CSV Export Path
CSV_EXPORT_DIR=./exports

# ======================
# Phase 3: Revenue Engine
# ======================

# Score >= this fires instant hot-lead alerts
HOT_LEAD_THRESHOLD=70

# WhatsApp alerts via Twilio (leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+919800000000

# Slack incoming webhook (leave blank to disable)
SLACK_WEBHOOK_URL=

# Email alerts via SMTP (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# HubSpot Private App token (leave blank to disable CRM sync)
HUBSPOT_API_KEY=

